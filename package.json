{
  "name": "special-needs-server",
  "version": "1.0.0",
  "description": "Backend API for Special Needs Children Registry",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "prod": "pm2 start src/server.js --name special-needs-api",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\"",
    "seed": "node scripts/seedData.js",
    "backup": "node scripts/backup.js"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "express": "^4.18.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.7.0",
    "socket.io": "^4.5.0",
    "multer": "^1.4.5",
    "cloudinary": "^1.32.0",
    "nodemailer": "^6.8.0",
    "redis": "^4.5.0",
    "express-validator": "^6.14.0",
    "winston": "^3.8.0",
    "xss": "^1.0.14",
    "express-fileupload": "^1.4.0",
    "sharp": "^0.31.0",
    "uuid": "^9.0.0",
    "dotenv": "^16.0.0",
    "agenda": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "jest": "^29.3.0",
    "supertest": "^6.3.0",
    "eslint": "^8.28.0",
    "prettier": "^2.8.0",
    "pm2": "^5.2.0",
    "prisma": "^6.5.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}