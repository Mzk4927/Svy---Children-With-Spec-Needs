generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  doctor
  viewer
  data_entry
}

enum RecordStatus {
  active
  archived
  transferred
  deleted
}

model User {
  id                   Int        @id @default(autoincrement())
  name                 String
  email                String     @unique
  password             String
  role                 UserRole   @default(viewer)
  organizationId       String
  permissions          String[]   @default([])
  profileImage         String?
  lastLogin            DateTime?
  isActive             Boolean    @default(true)
  twoFactorEnabled     Boolean    @default(false)
  twoFactorSecret      String?
  refreshToken         String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  recordsCreated       Record[]   @relation("CreatedRecords")
  recordsUpdated       Record[]   @relation("UpdatedRecords")
  auditLogs            AuditLog[]
}

model Record {
  id              Int          @id @default(autoincrement())
  name            String
  fatherName      String
  address         String
  contact         String
  age             Int
  disability      String
  advice          String?
  remarks         String?
  imageUrl        String?
  imagePublicId   String?
  organizationId  String
  status          RecordStatus @default(active)
  tags            String[]     @default([])
  createdById     Int
  lastUpdatedById Int?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       User         @relation("CreatedRecords", fields: [createdById], references: [id])
  lastUpdatedBy   User?        @relation("UpdatedRecords", fields: [lastUpdatedById], references: [id])
  auditLogs       AuditLog[]

  @@index([name])
  @@index([createdAt])
  @@index([organizationId, status])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  entityType String?
  entityId   Int?
  details    Json?
  ipAddress  String?
  userId     Int?
  recordId   Int?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
  record     Record?  @relation(fields: [recordId], references: [id])

  @@index([userId])
  @@index([recordId])
}
